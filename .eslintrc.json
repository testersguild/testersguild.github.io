{
  "env": {
    "browser": true,
    "es2021": true,
    "jest": true
  },
  "globals": {
    "global": "readonly",
    "module": "readonly",
    "escapeHtml": "readonly",
    "getCurrentLangKey": "readonly",
    "loadJson": "readonly",
    "saveJson": "readonly"
  },
  "extends": [
    "eslint:recommended",
    "plugin:jest/recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": ["jest"],
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "prefer-const": "error",
    "no-var": "error"
  },
  "overrides": [
    {
      "files": ["js/i18n.js"],
      "rules": {
        "no-unused-vars": "off"
      }
    }
  ]
}